# Upstash Redis — required for the star counter feature
# Vercel injects these automatically when you link the Upstash integration.
# To pull them locally: run `vercel env pull .env.local` in the project folder.

STORAGE_KV_REST_API_URL=your_upstash_rest_url_here
STORAGE_KV_REST_API_TOKEN=your_upstash_rest_token_here
STORAGE_KV_REST_API_READ_ONLY_TOKEN=your_upstash_read_only_token_here
STORAGE_KV_URL=your_upstash_kv_url_here
STORAGE_REDIS_URL=your_upstash_redis_url_here
